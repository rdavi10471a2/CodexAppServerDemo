@page "/"
@rendermode InteractiveServer

<PageTitle>Codex Control</PageTitle>

<section class="control-screen @(isConnectionPanelVisible ? string.Empty : "connection-hidden")">
    <header class="command-bar">
        <div class="title-strip">
            <RadzenButton Icon="dock_to_left" Text="@(isConnectionPanelVisible ? "Hide" : "Show")" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@ToggleConnectionPanel" />
            <div>
                <h1>Codex Control</h1>
                <span class="subtle-label">Workspace workflow</span>
            </div>
        </div>
        <span class="status-pill @(snapshot.IsServerStarted ? "online" : "offline")">
            @(snapshot.IsServerStarted ? "Server running" : "Server stopped")
        </span>
    </header>

    <main class="control-grid">
        @if (isConnectionPanelVisible)
        {
            <aside class="connection-panel" aria-label="Connection controls">
                <div class="panel-heading">
                    <div>
                        <span class="eyebrow">Connection</span>
                        <h2>Runtime</h2>
                    </div>
                </div>

                <label class="field">
                    <span>Codex executable</span>
                    <RadzenTextBox @bind-Value="codexExe" />
                </label>

                <label class="field">
                    <span>Model</span>
                    <RadzenTextBox @bind-Value="model" />
                </label>

                <div class="settings-pair">
                    <label class="field">
                        <span>Approval</span>
                        <RadzenTextBox @bind-Value="approvalPolicy" Disabled="true" />
                    </label>
                    <label class="field">
                        <span>Sandbox</span>
                        <RadzenTextBox @bind-Value="sandbox" Disabled="true" />
                    </label>
                </div>

                <div class="actions connection-actions">
                    <RadzenButton Icon="power_settings_new" Text="Start Server" ButtonStyle="ButtonStyle.Secondary" Click="@StartServer" Disabled="@busy" />
                    <RadzenButton Icon="forum" Text="Start Thread" ButtonStyle="ButtonStyle.Secondary" Click="@StartThread" Disabled="@(!snapshot.IsServerStarted || busy)" />
                </div>

                <div class="summary-stack">
                    <div>
                        <span>Thread</span>
                        <strong>@(snapshot.ThreadId ?? "not started")</strong>
                    </div>
                    <div>
                        <span>MCP</span>
                        <strong>localhost:6278</strong>
                    </div>
                </div>
            </aside>
        }

        <section class="work-panel">
            <div class="workspace-toolbar">
                <div class="workspace-path">
                    <span>CWD</span>
                    <strong>@repoRoot</strong>
                </div>
                <RadzenButton Icon="folder_open" Text="Browse" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Click="@BrowseForDirectory" Disabled="@busy" />
            </div>
            @if (!string.IsNullOrWhiteSpace(directorySnapshot.ErrorMessage))
            {
                <div class="inline-error">@directorySnapshot.ErrorMessage</div>
            }

            <RadzenTabs RenderMode="TabRenderMode.Client">
                <Tabs>
                    <RadzenTabsItem Text="Assistant">
                        <div class="assistant-layout">
                            <label class="prompt-panel">
                                <span>Prompt</span>
                                <RadzenTextArea @bind-Value="prompt" Rows="6" />
                            </label>

                            <div class="actions">
                                <RadzenButton Icon="send" Text="Send Turn" ButtonStyle="ButtonStyle.Primary" Click="@SendTurn" Disabled="@(!snapshot.IsServerStarted || busy)" />
                            </div>

                            <pre class="output-box assistant-output">@snapshot.AssistantText</pre>
                        </div>
                    </RadzenTabsItem>
                    <RadzenTabsItem Text="Status">
                        <pre class="output-box">@JoinLines(snapshot.StatusLines)</pre>
                    </RadzenTabsItem>
                    <RadzenTabsItem Text="Telemetry">
                        <pre class="output-box">@JoinLines(snapshot.TelemetryLines)</pre>
                    </RadzenTabsItem>
                    <RadzenTabsItem Text="Tools">
                        <pre class="output-box">@JoinLines(snapshot.ToolLines)</pre>
                    </RadzenTabsItem>
                    <RadzenTabsItem Text="Raw Protocol">
                        <pre class="output-box">@JoinLines(snapshot.RawLines)</pre>
                    </RadzenTabsItem>
                </Tabs>
            </RadzenTabs>
        </section>
    </main>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="error-banner">@errorMessage</div>
    }
</section>
