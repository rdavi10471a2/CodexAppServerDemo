@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Coding Services</PageTitle>

<section class="control-screen @(isConnectionPanelVisible ? string.Empty : "connection-hidden")">
    <header class="command-bar">
        <div class="title-strip">
            <div class="brand-lockup">
                <img style="height:40px; width:auto;" src="/images/cs_header_logo_56x40.svg" alt="Coding Services" />                <h1>Coding Services</h1>
            </div>
        </div>
        <RadzenButton Icon="dock_to_left"
                      Text="@(isConnectionPanelVisible ? "Hide Connection" : "Show Connection")"
                      ButtonStyle="ButtonStyle.Light"
                      Size="ButtonSize.Small"
                      Click="@ToggleConnectionPanel" />
    </header>

    <main class="control-grid" @ref="controlGrid">
        @if (isConnectionPanelVisible)
        {
            <div class="connection-shell" @ref="connectionPane">
                <ConnectionPanel Snapshot="@snapshot"
                                 Busy="@busy"
                                 McpUrl="@mcpUrl"
                                 @bind-CodexExe="@codexExe"
                                 @bind-Model="@model"
                                 @bind-ApprovalPolicy="@approvalPolicy"
                                 @bind-Sandbox="@sandbox"
                                 ToggleServer="@ToggleServer"
                                 StartThread="@StartThread" />
            </div>

            <div class="main-splitter" @ref="mainSplitter" title="Drag to resize connection panel" aria-hidden="true"></div>
        }

        <section class="work-panel" @ref="workPanel">
            <div class="workspace-toolbar">
                <div class="workspace-path">
                    <span>CWD</span>
                    <strong>@repoRoot</strong>
                </div>
                <div class="workspace-state">
                    <span class="state-chip @(snapshot.IsServerStarted ? "state-chip-ok" : "state-chip-muted")">
                        @(snapshot.IsServerStarted ? "Server running" : "Server stopped")
                    </span>
                    @if (snapshot.IsTurnRunning)
                    {
                        <span class="state-chip state-chip-running">Turn running</span>
                    }
                </div>
                <RadzenButton Icon="folder_open"
                              Text="Browse"
                              ButtonStyle="ButtonStyle.Secondary"
                              Size="ButtonSize.Small"
                              Click="@BrowseForDirectory"
                              Disabled="@busy" />
            </div>

            @if (!string.IsNullOrWhiteSpace(directorySnapshot.ErrorMessage))
            {
                <div class="inline-error">@directorySnapshot.ErrorMessage</div>
            }

            <RadzenTabs RenderMode="TabRenderMode.Client">
                <Tabs>
                    <RadzenTabsItem Text="Tasks">
                        <TasksTab WorkspaceRoot="@repoRoot" />
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Assistant">
                        <AssistantTab TranscriptHtml="@TranscriptHtml"
                                      TranscriptBodyHtml="@TranscriptBodyHtml"
                                      TranscriptText="@TranscriptText"
                                      CurrentTurnHtml="@CurrentTurnHtml"
                                      PermissionRequests="@snapshot.PermissionRequests"
                                      Attachments="@turnAttachments"
                                      AttachmentPickerKey="@attachmentPickerKey"
                                      @bind-ChatDraft="@chatDraft"
                                      IsServerStarted="@snapshot.IsServerStarted"
                                      Busy="@busy"
                                      SendChatDraft="@SendChatDraft"
                                      AttachFiles="@AttachTurnFiles"
                                      RemoveAttachment="@RemoveTurnAttachment"
                                      ClearHistory="@ClearChatHistory"
                                      ApprovePermission="@ApprovePermissionRequest"
                                      ApprovePermissionForSession="@ApprovePermissionRequestForSession"
                                      ApprovePermissionAlways="@ApprovePermissionRequestAlways"
                                      DenyPermission="@DenyPermissionRequest"
                                      CancelPermission="@CancelPermissionRequest" />
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Source">
                        <SourceTab Snapshot="@sourceSnapshot"
                                   @bind-Filter="@sourceFilter"
                                   SelectedPath="@selectedSourcePath"
                                   IsRebuildingIndex="@isRebuildingSourceIndex"
                                   ApplyFilter="@ApplySourceFilter"
                                   RebuildIndex="@RebuildSourceIndex"
                                   SelectFile="@SelectSourceFile" />
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Tests">
                        <SourceTab Snapshot="@testSourceSnapshot"
                                   @bind-Filter="@testSourceFilter"
                                   SelectedPath="@selectedTestSourcePath"
                                   IsRebuildingIndex="@isRebuildingSourceIndex"
                                   ApplyFilter="@ApplyTestSourceFilter"
                                   RebuildIndex="@RebuildSourceIndex"
                                   SelectFile="@SelectTestSourceFile" />
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Status">
                        <OutputTab Events="@snapshot.StatusEvents" EmptyText="No status events yet." />
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Telemetry">
                        <OutputTab Events="@snapshot.TelemetryEvents" EmptyText="No telemetry events yet." />
                    </RadzenTabsItem>

                    <RadzenTabsItem Text="Tools">
                        <OutputTab Events="@snapshot.ToolEvents" EmptyText="No tool events yet." />
                    </RadzenTabsItem>
                </Tabs>
            </RadzenTabs>
        </section>
    </main>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="error-banner">@errorMessage</div>
    }
</section>
